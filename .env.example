# =============================================================================
# Megan — environment configuration
# Copy to .env and fill in.  NEVER commit the real .env.
# =============================================================================

# --- Identity ---------------------------------------------------------------
MEGAN_NAME=Megan
# Your Telegram numeric user id (the REAL you).  Megan only talks to you.
# Find it by messaging the burner from your real account and reading the logs,
# or use @userinfobot.  Leave blank to accept the first DMer (dev only).
OWNER_TELEGRAM_ID=

# --- Telegram userbot (burner account) --------------------------------------
# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Burner phone number in international format, e.g. +15551234567
TELEGRAM_PHONE=
# Session file name (string session is also supported via TELEGRAM_STRING_SESSION)
TELEGRAM_SESSION_NAME=megan
TELEGRAM_STRING_SESSION=

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=
# Cheap first-pass classifier
MEGAN_CLASSIFY_MODEL=claude-haiku-4-5
# Triage reasoning, vision, doc-writing, agent summaries
MEGAN_REASONING_MODEL=claude-opus-4-8
# Soft monthly USD cap; Megan warns the owner past this (0 = disabled)
MEGAN_MONTHLY_COST_CAP_USD=50

# --- Transcription (voice notes) --------------------------------------------
# Provider: openai | local | none
TRANSCRIBE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
# For local whisper.cpp: absolute path to the `main`/`whisper-cli` binary + model
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=

# --- Postgres ---------------------------------------------------------------
DATABASE_URL=postgresql://megan:megan@localhost:5432/megan

# --- Linear -----------------------------------------------------------------
LINEAR_API_KEY=
# Optional: default team key for new issues (e.g. ENG)
LINEAR_DEFAULT_TEAM=

# --- Obsidian ---------------------------------------------------------------
# Path to a git-backed markdown vault Megan writes into.
OBSIDIAN_VAULT_PATH=./vault
# If true, Megan commits + pushes after each write (cron also does this).
OBSIDIAN_GIT_AUTOCOMMIT=true

# --- Proactivity / scheduling ----------------------------------------------
# Hard cap on simultaneously-open questions.  The spec's core guarantee.
MAX_OPEN_ASKS=4
# Quiet hours (local), inclusive start, exclusive end. No proactive pings here.
QUIET_HOURS_START=23
QUIET_HOURS_END=8
# Work-hours window for the backlog drip.
WORK_HOURS_START=9
WORK_HOURS_END=19
TIMEZONE=America/New_York
# How often (minutes) to drip the backlog when a slot is free.
BACKLOG_DRIP_MINUTES=150

# --- Agent monitoring (read-only SSH) ---------------------------------------
# Low-privilege private key that only reaches dev boxes. NEVER a prod key.
MONITOR_SSH_KEY_PATH=
MONITOR_SSH_KNOWN_HOSTS=

# --- Misc -------------------------------------------------------------------
LOG_LEVEL=INFO
DOWNLOAD_DIR=./downloads
